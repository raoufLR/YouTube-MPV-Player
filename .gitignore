# Build output
dist/
build/
# Spec file is tracked (needed for builds)
!*.spec

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# User data (auto-generated at runtime)
User/
Cache/
Logs/

# Large binaries (user provides their own)
mpv.exe
yt-dlp.exe

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store
